{
  "name": "@direct-democracy-solutions/elasticsearch-migration",
  "version": "1.0.1",
  "description": "Elasticsearch/OpenSearch migration tool",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "es-migrate": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "migrate": "tsx src/cli.ts",
    "prepublishOnly": "npm run build",
    "dry-release": "npm run release -- --ci --no-npm.publish --no-git.requireCleanWorkingDir --dry-run",
    "release": "release-it"
  },
  "keywords": [
    "elasticsearch",
    "opensearch",
    "migration",
    "database",
    "schema",
    "cli",
    "typescript"
  ],
  "author": "Ahmet Kasap",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/direct-democracy-solutions/elasticsearch-migration.git"
  },
  "bugs": {
    "url": "https://github.com/direct-democracy-solutions/elasticsearch-migration/issues"
  },
  "homepage": "https://github.com/direct-democracy-solutions/elasticsearch-migration#readme",
  "dependencies": {
    "@opensearch-project/opensearch": "^2.4.0",
    "commander": "^11.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "release-it": "^19.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
